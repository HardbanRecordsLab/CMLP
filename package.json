{
  "name": "hardban-records-lab-cmlp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build:frontend": "vite --config config/vite.config.ts build --base /",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build": "tsc -p config/tsconfig.json && npm run build:frontend && npm run build:server",
    "start": "node dist/server.cjs",
    "server": "tsx server.ts",
    "server:dev": "tsx watch server.ts",
    "server:prod": "pm2 start config/ecosystem.config.cjs",
    "preview": "vite --config config/vite.config.ts preview",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc -p config/tsconfig.json --noEmit",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,json,md}\" \"docs/**/*.md\"",
    "type-check": "tsc -p config/tsconfig.json --noEmit",
    "test": "vitest --config config/vite.config.ts run",
    "test:coverage": "vitest --config config/vite.config.ts run --coverage",
    "test:ui": "vitest --config config/vite.config.ts --ui",
    "db:generate": "drizzle-kit generate --config config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config config/drizzle.config.ts",
    "security:scan": "npm audit",
    "docker:build": "docker compose -f infrastructure/docker/docker-compose.yml build",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f infrastructure/docker/docker-compose.yml logs -f"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "hls.js": "^1.6.16",
    "i18next": "^26.3.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "music-metadata": "^11.13.0",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.19.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "recharts": "^3.8.1",
    "stripe": "^22.2.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  }
}
