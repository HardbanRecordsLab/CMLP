# ============================================================
# CMLP - Hardban Records Lab Environment Configuration
# Copy this file to .env.{production|development|test} and fill in real values
# Never commit actual secrets to version control
# ============================================================

# Application Settings
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/cmlp
VITE_API_URL=http://localhost:3000

# ============================================================
# DATABASE (PostgreSQL) - Drizzle ORM configuration
# ============================================================
SQL_HOST=localhost
SQL_USER=postgres
SQL_PASSWORD=your_secure_password_here
SQL_DB_NAME=cmlp

# ============================================================
# REDIS - Session cache and rate limiting
# ============================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=optional_redis_password

# ============================================================
# SECURITY - Secrets (use strong random values in production)
# ============================================================
HMAC_SECRET=generate-with-openssl-rand-hex-32
JWT_SECRET=generate-with-openssl-rand-hex-64

# ============================================================
# STRIPE PAYMENTS
# ============================================================
STRIPE_SECRET_KEY=sk_test_or_sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ============================================================
# WORDPRESS HEADLESS CMS
# ============================================================
WORDPRESS_API_URL=https://your-wp-site.com/wp-json
WORDPRESS_API_USER=application_username
WORDPRESS_API_PASSWORD=application_password

# ============================================================
# ADMIN SEED ACCOUNT (first super-admin created at startup)
# ============================================================
ADMIN_EMAIL=admin@your-company.com
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_NAME=System Admin

# ============================================================
# SECURITY & FEATURE FLAGS
# ============================================================
ENABLE_STRIPE=true
ENABLE_MFA=true
ENABLE_AUDIT_LOGS=true

