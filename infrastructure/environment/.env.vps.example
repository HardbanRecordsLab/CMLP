# Backend production env for VPS Docker Compose.
# Copy to infrastructure/environment/.env.production and replace every placeholder.

NODE_ENV=production
PORT=3000
APP_URL=https://api.hrl.pl

SQL_HOST=postgres
SQL_USER=hrl_admin
SQL_PASSWORD=replace_with_strong_postgres_password
SQL_DB_NAME=hrl_db

REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=replace_with_strong_redis_password

HMAC_SECRET=replace_with_64_hex_characters
JWT_SECRET=replace_with_96_random_characters

STRIPE_SECRET_KEY=sk_live_replace_with_actual_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_actual_webhook_secret
ENABLE_STRIPE=true
ENABLE_PAYU=false

SENDGRID_API_KEY=SG.replace_with_actual_key
FROM_EMAIL=noreply@hrl.pl

WORDPRESS_API_URL=https://cms.hrl.pl/wp-json
WORDPRESS_API_USER=replace_with_wp_user
WORDPRESS_API_PASSWORD=replace_with_wp_application_password

JWT_SECRET=replace_with_96_random_characters
# Firebase removed - using JWT auth

VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=replace_with_vault_token_if_used
VAULT_TRANSIT_KEY_NAME=my-key

SENTRY_DSN=
ENABLE_MFA=true
ENABLE_AUDIT_LOGS=true
