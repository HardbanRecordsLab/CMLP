# ============================================================
# CMLP Production Environment Configuration
# Copy this file to .env.production and fill in real values
# NEVER commit actual secrets to version control
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=production
PORT=3000
APP_URL=https://api.cmlp.hardbanrecordslab.online
FRONTEND_URL=https://cmlp.hardbanrecordslab.online

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://cmlp_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/cmlp_production
SQL_HOST=localhost
SQL_PORT=5432
SQL_USER=cmlp_user
SQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SQL_DB_NAME=cmlp_production

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ============================================================
# SECURITY (CRITICAL - Generate with: openssl rand -hex 32/64)
# ============================================================
# Generate: openssl rand -hex 32
HMAC_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Generate: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

# Generate: openssl rand -hex 32
REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Generate: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ============================================================
# STRIPE PAYMENTS
# ============================================================
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ============================================================
# WORDPRESS INTEGRATION
# ============================================================
WORDPRESS_API_URL=https://hardbanrecordslab.online/wp-json
WORDPRESS_API_USER=licensing_admin
WORDPRESS_API_PASSWORD=CHANGE_ME_WP_APP_PASSWORD

# ============================================================
# ADMIN SEED ACCOUNT (created on first startup)
# ============================================================
ADMIN_EMAIL=admin@hardbanrecordslab.online
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_NAME=Hardban Records Lab Admin

# ============================================================
# EMAIL (SMTP)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD
FROM_EMAIL=noreply@hardbanrecordslab.online
FROM_NAME=Hardban Records Lab

# ============================================================
# MEDIA STORAGE
# ============================================================
MEDIA_PATH=/opt/cmlp/media_files

# ============================================================
# OPTIONAL SERVICES
# ============================================================

# Sentry Error Tracking
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Google GenAI (AI tagging)
# GOOGLE_GENAI_API_KEY=CHANGE_ME

# PayU (Polish payment gateway)
# PAYU_API_KEY=CHANGE_ME
# PAYU_MERCHANT_ID=CHANGE_ME
# PAYU_MERCHANT_POS_ID=CHANGE_ME

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_STRIPE=true
ENABLE_PAYU=false
ENABLE_MFA=true
ENABLE_AUDIT_LOGS=true

# ============================================================
# GENERATION COMMANDS
# ============================================================
# Run these commands to generate secure secrets:
#
# openssl rand -hex 32  # For HMAC_SECRET, REFRESH_SECRET, WEBHOOK_SECRET
# openssl rand -hex 64  # For JWT_SECRET
#
# Example output:
# a1b2c3d4e5f6... (64 characters for hex 32)
# ============================================================
